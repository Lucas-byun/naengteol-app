{
  "rules": {
    ".read": true,
    "recipes": {
      "$recipeId": {
        "count": { ".write": "auth != null", ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000" },
        "name": { ".write": "auth != null", ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120" },
        "emoji": { ".write": "auth != null", ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 8)" },
        "lastDate": { ".write": "auth != null", ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/))" },
        "commTotalRating": { ".write": "auth != null", ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)" },
        "commRatingCount": { ".write": "auth != null", ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)" },
        "commAvgRating": { ".write": "auth != null", ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 5)" },
        "$other": { ".validate": false }
      }
    },
    "favs": {
      "$recipeId": {
        "count": { ".write": "auth != null", ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000" },
        "name": { ".write": "auth != null", ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120" },
        "$other": { ".validate": false }
      }
    },
    "community": {
      "approved": {
        "$postId": {
          ".write": "auth != null && root.child('adminUids').child(auth.uid).val() === true",
          ".validate": "!newData.exists() || newData.hasChildren(['id','recipe','recipeId','emoji','uid','date','likes'])",
          "id": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80" },
          "recipe": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120" },
          "recipeId": { ".validate": "newData.isString() && newData.val().length <= 80" },
          "emoji": { ".validate": "newData.isString() && newData.val().length <= 8" },
          "user": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 30)" },
          "nickname": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 30)" },
          "uid": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80" },
          "date": { ".validate": "newData.isString() && newData.val().matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)" },
          "text": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)" },
          "photo": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 350000)" },
          "rating": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 5)" },
          "likes": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000" },
          "approvedAt": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 40)" },
          "$other": { ".validate": false }
        }
      },
      "pending": {
        "$postId": {
          ".write": "auth != null && ((!newData.exists() && (data.child('uid').val() === auth.uid || root.child('adminUids').child(auth.uid).val() === true)) || (newData.exists() && (newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid || root.child('adminUids').child(auth.uid).val() === true)))",
          ".validate": "!newData.exists() || newData.hasChildren(['uid','recipe','recipeId','date'])",
          "uid": { ".validate": "newData.isString() && (newData.val() === auth.uid || root.child('adminUids').child(auth.uid).val() === true)" },
          "recipe": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120" },
          "recipeId": { ".validate": "newData.isString() && newData.val().length <= 80" },
          "emoji": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 8)" },
          "user": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 30)" },
          "nickname": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 30)" },
          "date": { ".validate": "newData.isString() && newData.val().matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)" },
          "text": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)" },
          "photo": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 350000)" },
          "rating": { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 5)" },
          "$other": { ".validate": false }
        }
      },
      "likes": {
        "$postId": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.val() === true"
          }
        }
      }
    },
    "users": {
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        "nickname": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length >= 1 && newData.val().length <= 15)" },
        "timestamp": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 40)" },
        "nicknameHistory": { ".validate": "!newData.exists() || newData.isList()" },
        "$other": { ".validate": true }
      }
    },
    "history": { ".write": "auth != null" },
    "cookLogs": {
      "$uid": {
        "$recipeId": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
        }
      }
    },
    "accessLogs": {
      "$date": {
        "$uid": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.val() === true"
        }
      }
    },
    "userHistory": {
      "$uid": {
        "entries": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isList()" },
        "updatedAt": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isString() && newData.val().length <= 40" },
        "$other": { ".validate": false }
      }
    },
    "nicknames": {
      "$encodedNick": {
        ".write": "auth != null",
        ".validate": "!newData.exists() || (newData.isString() && newData.val() === auth.uid)"
      }
    },
    "adminUids": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false,
        ".validate": "newData.val() === true"
      }
    }
  }
}
